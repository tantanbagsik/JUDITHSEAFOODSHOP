# MongoDB Connection String
# For local: mongodb://localhost:27017/judith-seafoods
# For Atlas: mongodb+srv://username:password@cluster.mongodb.net/?appName=Cluster0
MONGODB_URI=mongodb://localhost:27017/judith-seafoods

# NextAuth Configuration
# For production, use your actual domain (e.g., https://yourdomain.com)
NEXTAUTH_URL=http://localhost:3000

# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=your-super-secret-key-change-in-production

# Public App URL (use actual domain in production)
NEXT_PUBLIC_APP_URL=http://localhost:3000
